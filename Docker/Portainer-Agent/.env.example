# EXCEPTION (intentional): this stack is named "docker", NOT the usual folder-derived
# "portainer-agent". Special case for this project — do not "fix" it back. (Lowercase
# because Compose rejects uppercase.)
COMPOSE_PROJECT_NAME=docker
# MUST match the Portainer SERVER version on fastpi (the Pi) — a mismatched major/minor
# can fail to connect. Check the server version in the Portainer Web UI footer, or:
#   curl -sk https://<server>:9443/api/status
# Bump this whenever you upgrade Portainer on fastpi.
PORTAINER_AGENT_TAG=2.33.6
# Optional defence-in-depth shared secret (a random string, e.g. `openssl rand -hex 32`).
# Leave unset to match the current (no-secret) setup. If set, put the value here in .env,
# use the SAME value when adding the environment in Portainer, AND uncomment the
# environment block in docker-compose.yaml.
#AGENT_SECRET=
